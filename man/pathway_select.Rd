\description{
This function trains models based on survival analysis, binary, or multi-class classification. You can train individual ML/DL models or an ensemble of models. The function supports specifying hyper-parameters for individual models or the ensemble, and feature selection AUC, specificity cutoff.
}
\details{
Default hyperparameters are provided for each supported model depending
on the prediction task (\code{"binary"}, \code{"categorical"}, or \code{"survival"}).
Users may override these defaults by supplying custom parameter lists
through \code{param.indiv} or \code{param.ens}. If these arguments are set to
\code{NULL}, the defaults described below are used.

\strong{Multi-class classification defaults}
\itemize{
\item \code{"XG"} (xgboost): \code{max_depth = 2}, \code{eta = 0.1}, \code{nrounds = 50}
\item \code{"RF"} (random forest): \code{ntree = 500}
\item \code{"EN"} (elastic net): \code{nfolds = 3}, \code{s = "lambda.1se"}
\item \code{"ADB"} (one-vs-rest AdaBoost): \code{tree_depth = 3}, \code{n_rounds = 200}
\item \code{"MB"} (one-vs-rest model-based boosting): \code{mstop = 300}
\item \code{"GB"} (gradient boosting): \code{n.trees = 50}, \code{interaction.depth = 6},
\code{shrinkage = 0.1}
\item \code{"KNN"} (k-nearest neighbors): cross-validation with
\code{trainControl(method = "cv", number = 3, classProbs = TRUE)}
\item \code{"SVM"} (support vector machine): \code{kernel = "radial"}, \code{cost = 50},
\code{gamma = 0.75}
\item \code{"NB"} (naive Bayes): \code{laplace = 10}, \code{threshold = 0.001}
\item \code{"DCT"} (decision tree): \code{cp = 0.001}
\item \code{"NN"} (neural network): \code{hidden = c(8,4)}, \code{rep = 1}
}

\strong{Binary classification defaults}
\itemize{
\item \code{"XG"} (xgboost): \code{max_depth = 2}, \code{eta = 0.1}, \code{nthread = 2},
\code{nrounds = 500}, \code{objective = "binary:logistic"}
\item \code{"RF"} (random forest): \code{ntree = 500}
\item \code{"EN"} (elastic net): \code{alpha = 0.2}, \code{family = "binomial"},
\code{s = "lambda.1se"}
\item \code{"ADB"} (AdaBoost): \code{tree_depth = 3}, \code{n_rounds = 200}
\item \code{"MB"} (model-based boosting): \code{mstop = 300}
\item \code{"GB"} (gradient boosting): \code{cv.folds = 10}, \code{shrinkage = 0.01},
\code{n.minobsinnode = 2}, \code{n.trees = 500}, \code{distribution = "bernoulli"}
\item \code{"KNN"} (k-nearest neighbors): \code{k = 5}
\item \code{"NN"} (neural network): \code{hidden = c(8,4)}, \code{rep = 1}
\item \code{"NB"} (naive Bayes): \code{usekernel = TRUE}
\item \code{"DCT"} (decision tree): \code{method = "class"}
}

\strong{Survival analysis defaults}
\itemize{
\item \code{"XG"} (survival xgboost): \code{eta = 0.1}, \code{nrounds = 1000}
\item \code{"RF"} (random survival forest): \code{ntree = 2000}, \code{max.depth = 10},
\code{importance = TRUE}
\item \code{"EN"} (elastic net Cox model): \code{alpha = 0.2}, \code{s = "lambda.min"}
\item \code{"MB"} (model-based boosting): \code{mstop = 300}
\item \code{"ADB"} (time-point AdaBoost survival risk): \code{tree_depth = 3},
\code{n_rounds = 200}
\item \code{"GB"} (gradient boosting): \code{n.trees = 1000}, \code{interaction.depth = 10},
\code{shrinkage = 0.005}, \code{bag.fraction = 0.5}
\item \code{"SVM"} (survival SVM): \code{gamma.mu = 0.01}, \code{opt.meth = "quadprog"},
\code{kernel = "add_kernel"}
\item \code{"DCT"} (decision tree): \code{minsplit = 10}, \code{maxdepth = 10},
\code{cp = 0.001}
